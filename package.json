{
  "name": "chargeshare",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "build": "npm run build --workspace apps/frontend",
    "lint": "npm run lint --workspace apps/frontend && npm run lint --workspace apps/backend",
    "test": "npm run test --workspace apps/frontend && npm run test --workspace apps/backend",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:setup": "npm run db:setup --workspace apps/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2"
  }
}
